# Plantilla — copia a .env y completa con los valores reales.
# NUNCA pongas valores reales aquí (este archivo se versiona).

# Tickets por script (uno por servicio MP)
TICKET_ACTIVAS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TICKET_CA=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TICKET_OC=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TICKET_CRM=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TICKET_BACKFILL=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...

# HTTP — segundos entre requests (OC necesita >=3.0 por rate limit)
SLEEP_BETWEEN=2.0
SLEEP_BETWEEN_OC=3.0
SLEEP_BETWEEN_BACKFILL=3.0

# Backend de cursores: "supabase" (default, para la nube) o "file" (local)
CURSOR_BACKEND=supabase

# Tuning por script
LIC_MAX_POR_RUN=200
CA_VENTANA_HORAS=1
OC_DIAS_ATRAS=1
OC_MAX_DETALLE=400
CRM_LIMIT=2000
ESTADOS_DIAS_ATRAS=2
BACKFILL_LOTE=1500
BACKFILL_OC_LOTE=1500
